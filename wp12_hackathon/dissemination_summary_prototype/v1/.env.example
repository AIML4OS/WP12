# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# API keys  (only fill the ones you actually use)
# ---------------------------------------------------------------------------
SSP_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Cache directories
# _bootstrap.py points these to .cache/{hf,docling,torch,easyocr} by default.
# Override here to redirect the cache to a different location.
# ---------------------------------------------------------------------------
# HF_HOME=
# DOCLING_ARTIFACTS_PATH=
# TORCH_HOME=
# EASYOCR_MODULE_PATH=

